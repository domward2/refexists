/*
  Content-Security-Policy: default-src 'self'; connect-src https://api.crossref.org https://api.datacite.org https://doi.org https://api.openalex.org https://eutils.ncbi.nlm.nih.gov https://openlibrary.org; img-src 'self' data:; style-src 'self'; font-src 'self'; script-src 'self'; base-uri 'none'; form-action 'none'; object-src 'none'; frame-ancestors 'none'
